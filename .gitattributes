# ======================================================================
# UNITY PROJECT - PRODUCTION READY .gitattributes
# Tujuan:
# - Konsistensi line endings antar OS
# - Git LFS untuk file besar
# - Merge strategy aman untuk Unity YAML
# - Menghindari corruption pada binary assets
# ======================================================================


# ======================================================================
# TEXT FILES (WAJIB)
# ======================================================================

# Source Code
*.cs                 text diff=csharp
*.js                 text
*.boo                text
*.shader             text
*.compute            text
*.cginc              text
*.hlsl               text
*.glslinc            text

# Unity YAML Assets
*.unity              text
*.prefab             text
*.asset              text
*.meta               text
*.mat                text
*.anim               text
*.mask               text
*.controller         text
*.overrideController text
*.playable           text
*.spriteatlas        text
*.terrainlayer       text
*.inputactions       text
*.lighting           text
*.flare              text
*.fontsettings       text
*.guiskin            text
*.mixer              text
*.physicMaterial     text
*.physicsMaterial2D  text
*.preset             text
*.renderTexture      text
*.shadervariants     text
*.signal             text
*.state              text
*.stateMachine       text
*.timeline           text
*.vfx                text
*.asmdef             text
*.asmref             text

# Config / Data
*.json               text
*.xml                text
*.yaml               text
*.yml                text
*.txt                text
*.md                 text
*.csv                text
*.tsv                text
*.log                text

# Package Manager
Packages/*.json      text
ProjectSettings/*.asset text

# Build / CI
*.gradle             text
*.properties         text
*.bat                text eol=crlf
*.cmd                text eol=crlf
*.sh                 text eol=lf
*.ps1                text eol=crlf


# ======================================================================
# UNITY SMART MERGE (YAML MERGE SUPPORT)
# ======================================================================

*.unity              merge=unityyamlmerge eol=lf
*.prefab             merge=unityyamlmerge eol=lf
*.asset              merge=unityyamlmerge eol=lf
*.meta               merge=unityyamlmerge eol=lf
*.mat                merge=unityyamlmerge eol=lf
*.anim               merge=unityyamlmerge eol=lf
*.controller         merge=unityyamlmerge eol=lf


# ======================================================================
# GIT LFS — 3D ASSETS
# ======================================================================

*.fbx                filter=lfs diff=lfs merge=lfs -text
*.obj                filter=lfs diff=lfs merge=lfs -text
*.blend              filter=lfs diff=lfs merge=lfs -text
*.max                filter=lfs diff=lfs merge=lfs -text
*.dae                filter=lfs diff=lfs merge=lfs -text
*.3ds                filter=lfs diff=lfs merge=lfs -text
*.c4d                filter=lfs diff=lfs merge=lfs -text
*.mb                 filter=lfs diff=lfs merge=lfs -text
*.ma                 filter=lfs diff=lfs merge=lfs -text
*.skp                filter=lfs diff=lfs merge=lfs -text


# ======================================================================
# GIT LFS — TEXTURES / IMAGES
# ======================================================================

*.psd                filter=lfs diff=lfs merge=lfs -text
*.psb                filter=lfs diff=lfs merge=lfs -text
*.tga                filter=lfs diff=lfs merge=lfs -text
*.png                filter=lfs diff=lfs merge=lfs -text
*.jpg                filter=lfs diff=lfs merge=lfs -text
*.jpeg               filter=lfs diff=lfs merge=lfs -text
*.bmp                filter=lfs diff=lfs merge=lfs -text
*.gif                filter=lfs diff=lfs merge=lfs -text
*.exr                filter=lfs diff=lfs merge=lfs -text
*.hdr                filter=lfs diff=lfs merge=lfs -text
*.tif                filter=lfs diff=lfs merge=lfs -text
*.tiff               filter=lfs diff=lfs merge=lfs -text
*.dds                filter=lfs diff=lfs merge=lfs -text
*.ktx                filter=lfs diff=lfs merge=lfs -text


